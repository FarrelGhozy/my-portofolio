---
import Layout from '../layouts/Layout.astro';

const navLinks = [
  { href: '#about', label: 'About' },
  { href: '#skills', label: 'Skills' },
  { href: '#projects', label: 'Projects' },
  { href: '#resume', label: 'Resume' },
  { href: '#research', label: 'Research' },
  { href: '#contact', label: 'Contact' },
];

const skills = [
  {
    category: 'Frontend',
    items: ['JavaScript', 'TypeScript', 'HTML', 'CSS', 'React', 'Tailwind CSS', 'Astro', 'Bootstrap'],
    icon: 'frontend',
  },
  {
    category: 'Backend',
    items: ['Node.js', 'Express', 'Python', 'PHP', 'C++', 'REST API'],
    icon: 'backend',
  },
  {
    category: 'Mobile',
    items: ['Kotlin', 'Android Studio', 'XML Layout'],
    icon: 'mobile',
  },
  {
    category: 'Database & Infra',
    items: ['MongoDB', 'MySQL', 'Docker', 'Linux', 'Windows', 'Nginx', 'Proxmox', 'K3s', 'Vercel'],
    icon: 'infra',
  },
  {
    category: 'ML / AI',
    items: ['TensorFlow', 'PyTorch', 'scikit-learn', 'Pandas', 'NumPy', 'Jupyter'],
    icon: 'ml',
  },
  {
    category: 'Non-Technical',
    items: ['Time Management', 'Communication', 'Problem Solving', 'Team Leadership'],
    icon: 'nontech',
  },
];

const projects = [
  {
    title: 'Kasir UTC 02',
    desc: 'Point-of-sale system for Unida Technology Centre workshop. Features transaction management, service ticketing, inventory tracking, and WhatsApp bot integration.',
    tags: ['JavaScript', 'Node.js', 'Express', 'MongoDB', 'WAHA', 'Vercel'],
    link: 'https://github.com/FarrelGhozy/Kasir_UTC_02',
    status: 'Production',
  },
  {
    title: 'CNN vs Transfer Learning untuk Klasifikasi Citra',
    desc: 'Research project comparing CNN architectures and Transfer Learning approaches for image classification. Includes model training, evaluation pipelines, and performance analysis.',
    tags: ['Python', 'TensorFlow', 'PyTorch', 'Jupyter', 'Deep Learning'],
    link: 'https://github.com/FarrelGhozy/CNN-vs-Transfer-Learning-untuk-Klasifikasi-Citra',
    status: 'Research',
  },
  {
    title: 'sembako-chain-ai',
    desc: 'AI-based hybrid food distribution ecosystem for price stabilization and economic inclusion. Combines multi-criteria analysis with ML-powered recommendations.',
    tags: ['TypeScript', 'AI', 'Recommendation System', 'Multi-criteria'],
    link: 'https://github.com/FarrelGhozy/sembako-chain-ai',
    status: 'Active',
  },
  {
    title: 'retakId',
    desc: 'Crowdsourcing platform for early detection of landslide soil cracks. Community-driven reporting, mapping, and alert system.',
    tags: ['JavaScript', 'Crowdsourcing', 'Mapping', 'Community'],
    link: 'https://github.com/FarrelGhozy/retakId',
    status: 'Active',
  },
  {
    title: 'Deforest.id',
    desc: 'LaTeX-based academic writing project focused on deforestation analysis and environmental research documentation.',
    tags: ['LaTeX', 'Academic', 'Research'],
    link: 'https://github.com/FarrelGhozy/Deforest.id',
    status: 'Research',
  },
];

const collabProjects = [
  {
    title: 'corrupt (jaweed3)',
    desc: 'Corruption Education Simulator — interactive simulation to educate about corruption impacts. Contributor to this collaborative project.',
    tags: ['JavaScript', 'Education', 'Simulation'],
    link: 'https://github.com/jaweed3/corrupt',
  },
  {
    title: 'RescueVision (jaweed3)',
    desc: 'Lightweight sovereign AI for on-device victim localization in post-disaster aerial assessment. Collaborator on ML model development.',
    tags: ['Jupyter', 'Python', 'AI', 'Disaster Response'],
    link: 'https://github.com/jaweed3/RescueVision',
  },
];

const basePath = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const education = {
  university: 'Universitas Darussalam Gontor',
  location: 'Ponorogo, Indonesia',
  major: 'Teknik Informatika',
  semester: 'Semester 5',
  gpa: '3.79/4.00',
};

const awards = [
  {
    title: 'Juara 2, Coding Day',
    year: '2026',
    desc: 'Berhasil meraih juara 2 dalam bidang pembuatan web dari seluruh mahasiswa Teknik Informatika',
    image: 'award-coding-day.webp',
  },
  {
    title: 'The Best Thematic, Hackathon SRE ITB',
    year: '2026',
    desc: 'Meraih penghargaan The Best Thematic pada Hackathon SRE ITB 2026',
    image: 'award-sre-itb.webp',
  },
];

const organizations = [
  {
    name: 'Himpunan Mahasiswa Teknik Informatika',
    role: 'Kader Akademik',
    period: 'April 2024 – Mei 2025',
  },
  {
    name: 'Bengel TI',
    role: 'Kader',
    period: 'Maret 2024 – Maret 2025',
  },
  {
    name: 'Asisten Praktikum Dasar Pemrograman',
    role: 'Asisten Praktikum',
    period: 'Februari 2025 – Agustus 2025',
  },
  {
    name: 'Asisten Praktikum Algoritma dan Struktur Data',
    role: 'Asisten Praktikum',
    period: 'Februari 2025 – Agustus 2025',
  },
  {
    name: 'Festival Teknik Informatika',
    role: 'Ketua',
    period: 'Agustus 2024 – September 2024',
  },
  {
    name: 'Himpunan Mahasiswa Teknik Informatika',
    role: 'Ketua',
    period: 'Mei 2025 – Sekarang',
  },
  {
    name: 'Bengel Unida Technology Center',
    role: 'Ketua Staff Unit Usaha',
    period: 'April 2025 – Sekarang',
  },
];
---

<Layout>

<!-- Navbar -->
<nav class="fixed top-0 left-0 right-0 z-50 glass">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="#" class="text-xl font-bold tracking-tight">
      <span class="text-brand-400">&lt;</span>
      <span class="text-white">FG</span>
      <span class="text-brand-400">/&gt;</span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm font-medium text-surface-200 hover:text-brand-400 transition-colors duration-200"
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Mobile Menu Button -->
    <button id="mobile-menu-btn" class="md:hidden text-surface-200 hover:text-brand-400 transition-colors" aria-label="Toggle menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-brand-900/50 px-6 py-4 space-y-3">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="block text-sm font-medium text-surface-200 hover:text-brand-400 transition-colors"
      >
        {link.label}
      </a>
    ))}
  </div>
</nav>

<!-- Hero Section -->
<section class="relative min-h-screen flex items-center justify-center bg-surface-950 bg-grid overflow-hidden">
  <!-- Radial Glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[600px] bg-radial-glow"></div>

  <!-- Floating Orbs -->
  <div class="absolute top-1/4 left-1/4 w-3 h-3 rounded-full bg-brand-500/40 animate-float"></div>
  <div class="absolute top-1/3 right-1/4 w-2 h-2 rounded-full bg-brand-400/30 animate-float animation-delay-400"></div>
  <div class="absolute bottom-1/3 left-1/3 w-4 h-4 rounded-full bg-brand-600/20 animate-float animation-delay-800"></div>

  <!-- Orbit Ring -->
  <div class="absolute w-[300px] h-[300px] md:w-[400px] md:h-[400px] border border-brand-800/20 rounded-full">
    <div class="absolute top-1/2 left-0 w-3 h-3 -translate-y-1/2 rounded-full bg-brand-500 animate-orbit shadow-[0_0_15px_rgba(59,130,246,0.5)]"></div>
  </div>

  <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
    <!-- Greeting Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass mb-8 animate-fade-in-up">
      <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
      <span class="text-sm font-medium text-surface-200">Available for collaboration</span>
    </div>

    <!-- Main Heading -->
    <h1 class="text-4xl sm:text-5xl md:text-7xl font-black tracking-tight mb-6">
      <span class="text-white">Hi, I'm </span>
      <span class="text-brand-400 glow-text">Farrel Ghozy</span>
    </h1>

    <!-- Subtitle -->
    <p class="text-lg sm:text-xl md:text-2xl font-light text-surface-200 mb-4">
      Junior Web Developer
      <span class="text-brand-500 mx-2">&</span>
      Informatics Student
    </p>

    <!-- Description -->
    <p class="text-base md:text-lg text-surface-200/70 max-w-2xl mx-auto mb-10">
      Learning full-stack development, experimenting with machine learning,
      and building projects one commit at a time.
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#projects"
        class="group px-8 py-3.5 bg-brand-600 hover:bg-brand-500 text-white font-semibold rounded-xl transition-all duration-300 shadow-lg shadow-brand-900/50 hover:shadow-brand-700/50 hover:-translate-y-0.5"
      >
        View My Work
        <span class="inline-block ml-2 transition-transform group-hover:translate-x-1">→</span>
      </a>
      <a
        href="#contact"
        class="px-8 py-3.5 border border-brand-700/50 hover:border-brand-500 text-brand-400 font-semibold rounded-xl transition-all duration-300 hover:bg-brand-950/50 hover:-translate-y-0.5"
      >
        Get In Touch
      </a>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-5 h-5 text-brand-500/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </div>
</section>

<!-- About Section -->
<section id="about" class="py-24 md:py-32 relative">
  <div class="absolute inset-0 bg-grid opacity-30"></div>
  <div class="relative max-w-6xl mx-auto px-6">
    <!-- Section Header -->
    <div class="flex items-center gap-4 mb-16">
      <span class="text-brand-500 font-mono text-sm">01.</span>
      <h2 class="text-3xl md:text-4xl font-bold text-white">About Me</h2>
      <div class="flex-1 max-w-xs gradient-line"></div>
    </div>

    <div class="grid md:grid-cols-5 gap-12 items-start">
      <!-- Text -->
      <div class="md:col-span-3 space-y-5 text-surface-200/80">
        <p>
          I'm an Informatics student at
          <span class="text-brand-400 font-medium">Universitas Darussalam Gontor</span>
          passionate about web development and machine learning. I'm still
          learning and growing as a developer, and I love building projects
          that solve real problems.
        </p>
        <p>
          Currently working on a point-of-sale system for
          <span class="text-brand-400 font-medium">Unida Technology Centre</span>
          using JavaScript, Node.js, and MongoDB — integrating WhatsApp bot
          automation and inventory management features.
        </p>
        <p>
          I'm also exploring deep learning — comparing CNN architectures
          with Transfer Learning for image classification, and building
          ML pipelines with Python and Jupyter.
        </p>
        <p>
          I'm continuously learning new technologies and improving my skills
          through hands-on projects, coursework, and open source collaboration.
        </p>

        <!-- Quick Facts -->
        <div class="grid grid-cols-2 gap-4 pt-4">
          <div class="flex items-center gap-3">
            <span class="text-brand-500">▹</span>
            <span>Web Development</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-brand-500">▹</span>
            <span>Machine Learning</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-brand-500">▹</span>
            <span>Android (Kotlin)</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-brand-500">▹</span>
            <span>Open Source</span>
          </div>
        </div>
      </div>

      <!-- Profile Card -->
      <div class="md:col-span-2">
        <div class="relative group">
          <div class="absolute -inset-0.5 bg-gradient-to-br from-brand-600 to-brand-800 rounded-2xl opacity-30 group-hover:opacity-50 blur transition-opacity duration-500"></div>
          <div class="relative bg-surface-900 border border-brand-800/30 rounded-2xl p-8 glow-border">
            <!-- Avatar -->
            <div class="w-32 h-32 mx-auto mb-6 rounded-full overflow-hidden ring-2 ring-brand-500/30 shadow-lg shadow-brand-900/50">
              <img src={`${basePath}fotoProfil.webp`} alt="Farrel Ghozy" class="w-full h-full object-cover" />
            </div>
            <div class="text-center space-y-2">
              <h3 class="text-xl font-bold text-white">Farrel Ghozy Affifudin</h3>
              <p class="text-brand-400 text-sm font-medium">Informatics Student</p>
              <p class="text-surface-200/60 text-sm">Universitas Darussalam Gontor</p>
            </div>
            <div class="mt-6 pt-6 border-t border-brand-800/30 flex justify-center gap-4">
              <a href="https://github.com/FarrelGhozy" target="_blank" rel="noopener noreferrer" class="text-surface-200/60 hover:text-brand-400 transition-colors" aria-label="GitHub">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              </a>
              <a href="mailto:farrelafif05@gmail.com" target="_blank" rel="noopener noreferrer" class="text-surface-200/60 hover:text-brand-400 transition-colors" aria-label="Email">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              </a>
              <a href="https://linkedin.com/in/farrelghozy" target="_blank" rel="noopener noreferrer" class="text-surface-200/60 hover:text-brand-400 transition-colors" aria-label="LinkedIn">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
              <a href="https://instagram.com/farrelgzy" target="_blank" rel="noopener noreferrer" class="text-surface-200/60 hover:text-brand-400 transition-colors" aria-label="Instagram">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.5 6.5h.01M12 2a10 10 0 00-3.16.54 10.01 10.01 0 00-6.3 6.3A10 10 0 0012 22a10 10 0 0010-10 10.01 10.01 0 00-6.3-6.3A10 10 0 0012 2zm0 4a6 6 0 100 12 6 6 0 000-12zm-4 6a4 4 0 118 0 4 4 0 01-8 0z"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Skills Section -->
<section id="skills" class="py-24 md:py-32 bg-surface-900/50 relative">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex items-center gap-4 mb-16">
      <span class="text-brand-500 font-mono text-sm">02.</span>
      <h2 class="text-3xl md:text-4xl font-bold text-white">Tech Stack</h2>
      <div class="flex-1 max-w-xs gradient-line"></div>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {skills.map((skill) => (
        <div
          class="group relative bg-surface-900/80 border border-brand-900/30 rounded-2xl p-6 card-hover"
        >
          <!-- Category Icon -->
          <div class="w-12 h-12 rounded-xl bg-brand-950 border border-brand-800/30 flex items-center justify-center mb-4 group-hover:border-brand-600/50 transition-colors">
            {skill.icon === 'frontend' && (
              <svg class="w-6 h-6 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            )}
            {skill.icon === 'backend' && (
              <svg class="w-6 h-6 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" /></svg>
            )}
            {skill.icon === 'mobile' && (
              <svg class="w-6 h-6 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
            )}
            {skill.icon === 'infra' && (
              <svg class="w-6 h-6 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
            )}
            {skill.icon === 'ml' && (
              <svg class="w-6 h-6 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>
            )}
            {skill.icon === 'nontech' && (
              <svg class="w-6 h-6 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            )}
          </div>

          <h3 class="text-lg font-bold text-white mb-4">{skill.category}</h3>

          <div class="flex flex-wrap gap-2">
            {skill.items.map((item) => (
              <span class="px-3 py-1 text-xs font-medium rounded-lg bg-brand-950/80 text-brand-300 border border-brand-800/30">
                {item}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Projects Section -->
<section id="projects" class="py-24 md:py-32 relative">
  <div class="absolute inset-0 bg-grid opacity-20"></div>
  <div class="relative max-w-6xl mx-auto px-6">
    <div class="flex items-center gap-4 mb-16">
      <span class="text-brand-500 font-mono text-sm">03.</span>
      <h2 class="text-3xl md:text-4xl font-bold text-white">Featured Projects</h2>
      <div class="flex-1 max-w-xs gradient-line"></div>
    </div>

    <div class="space-y-8">
      {projects.map((project) => (
        <div class="group relative bg-surface-900/60 border border-brand-900/30 rounded-2xl overflow-hidden card-hover">
          <div class="p-8 md:p-10">
            <div class="flex items-start justify-between mb-4">
              <div>
                <div class="flex items-center gap-3 mb-2">
                  <h3 class="text-xl md:text-2xl font-bold text-white group-hover:text-brand-400 transition-colors">
                    {project.title}
                  </h3>
                  <span class={`px-2.5 py-0.5 text-xs font-semibold rounded-full ${
                    project.status === 'Production'
                      ? 'bg-green-900/50 text-green-400 border border-green-700/30'
                      : project.status === 'Active'
                      ? 'bg-blue-900/50 text-blue-400 border border-blue-700/30'
                      : 'bg-amber-900/50 text-amber-400 border border-amber-700/30'
                  }`}>
                    {project.status}
                  </span>
                </div>
                <p class="text-surface-200/70 leading-relaxed max-w-2xl">
                  {project.desc}
                </p>
              </div>
              <a
                href={project.link}
                target="_blank"
                rel="noopener noreferrer"
                class="hidden md:flex items-center justify-center w-10 h-10 rounded-lg border border-brand-800/30 text-brand-400 hover:bg-brand-950 hover:border-brand-600 transition-all flex-shrink-0"
                aria-label={`View ${project.title}`}
              >
