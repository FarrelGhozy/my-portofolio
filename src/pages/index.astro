---
import Layout from '../layouts/Layout.astro';

const navLinks = [
  { href: '#about', label: 'About' },
  { href: '#skills', label: 'Skills' },
  { href: '#projects', label: 'Projects' },
  { href: '#resume', label: 'Resume' },
  { href: '#research', label: 'Research' },
  { href: '#contact', label: 'Contact' },
];

const skills = [
  {
    category: 'Frontend',
    items: [
      { name: 'JavaScript', level: 5 },
      { name: 'TypeScript', level: 4 },
      { name: 'React', level: 4 },
      { name: 'Tailwind CSS', level: 4 },
      { name: 'Astro', level: 4 },
      { name: 'HTML & CSS', level: 5 },
      { name: 'Bootstrap', level: 3 },
    ],
    icon: 'frontend',
  },
  {
    category: 'Backend',
    items: [
      { name: 'Node.js', level: 4 },
      { name: 'Express', level: 4 },
      { name: 'Python', level: 3 },
      { name: 'PHP', level: 3 },
      { name: 'C++', level: 3 },
      { name: 'REST API', level: 4 },
    ],
    icon: 'backend',
  },
  {
    category: 'Mobile',
    items: [
      { name: 'Kotlin', level: 3 },
      { name: 'Android Studio', level: 3 },
      { name: 'XML Layout', level: 3 },
    ],
    icon: 'mobile',
  },
  {
    category: 'Database & Infra',
    items: [
      { name: 'MongoDB', level: 4 },
      { name: 'MySQL', level: 3 },
      { name: 'Docker', level: 3 },
      { name: 'Linux', level: 4 },
      { name: 'Nginx', level: 3 },
      { name: 'Proxmox', level: 3 },
      { name: 'K3s', level: 2 },
      { name: 'Vercel', level: 3 },
    ],
    icon: 'infra',
  },
  {
    category: 'ML / AI',
    items: [
      { name: 'TensorFlow', level: 3 },
      { name: 'PyTorch', level: 3 },
      { name: 'Pandas', level: 4 },
      { name: 'NumPy', level: 4 },
      { name: 'scikit-learn', level: 3 },
      { name: 'Jupyter', level: 4 },
    ],
    icon: 'ml',
  },
  {
    category: 'Professional',
    items: [
      { name: 'Time Management', level: 4 },
      { name: 'Communication', level: 5 },
      { name: 'Problem Solving', level: 5 },
      { name: 'Team Leadership', level: 4 },
    ],
    icon: 'nontech',
  },
];

const projects = [
  {
    title: 'Kasir UTC 02',
    desc: 'Point-of-sale system for Unida Technology Centre workshop. Features transaction management, service ticketing, inventory tracking, and WhatsApp bot integration with WAHA.',
    tags: ['Node.js', 'Express', 'MongoDB', 'WAHA', 'Vercel'],
    link: 'https://github.com/FarrelGhozy/Kasir_UTC_02',
    status: 'Production',
    color: 'teal',
  },
  {
    title: 'CNN vs Transfer Learning',
    desc: 'Research project comparing CNN architectures and Transfer Learning approaches for image classification. Includes model training, evaluation pipelines, and performance analysis.',
    tags: ['Python', 'TensorFlow', 'PyTorch', 'Jupyter', 'Deep Learning'],
    link: 'https://github.com/FarrelGhozy/CNN-vs-Transfer-Learning-untuk-Klasifikasi-Citra',
    status: 'Research',
    color: 'amber',
  },
  {
    title: 'Sembako Chain AI',
    desc: 'AI-based hybrid food distribution ecosystem for price stabilization and economic inclusion. Combines multi-criteria analysis with ML-powered recommendations.',
    tags: ['TypeScript', 'AI', 'Recommendation System', 'Multi-criteria'],
    link: 'https://github.com/FarrelGhozy/sembako-chain-ai',
    status: 'Active',
    color: 'purple',
  },
  {
    title: 'Retak ID',
    desc: 'Crowdsourcing platform for early detection of landslide soil cracks. Community-driven reporting, interactive mapping, and alert system.',
    tags: ['JavaScript', 'Crowdsourcing', 'Mapping', 'Community'],
    link: 'https://github.com/FarrelGhozy/retakId',
    status: 'Active',
    color: 'emerald',
  },
  {
    title: 'Deforest.id',
    desc: 'LaTeX-based academic writing project focused on deforestation analysis and environmental research documentation.',
    tags: ['LaTeX', 'Academic', 'Research'],
    link: 'https://github.com/FarrelGhozy/Deforest.id',
    status: 'Research',
    color: 'amber',
  },
];

const collabProjects = [
  {
    title: 'Corrupt (jaweed3)',
    desc: 'Corruption Education Simulator — interactive simulation to educate about corruption impacts. Contributed to this collaborative project.',
    tags: ['JavaScript', 'Education', 'Simulation'],
    link: 'https://github.com/jaweed3/corrupt',
  },
  {
    title: 'RescueVision (jaweed3)',
    desc: 'Lightweight sovereign AI for on-device victim localization in post-disaster aerial assessment. Collaborated on ML model development.',
    tags: ['Jupyter', 'Python', 'AI', 'Disaster Response'],
    link: 'https://github.com/jaweed3/RescueVision',
  },
];

const basePath = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const education = {
  university: 'Universitas Darussalam Gontor',
  location: 'Ponorogo, Indonesia',
  major: 'Informatics Engineering',
  semester: 'Semester 5',
  gpa: '3.79/4.00',
};

const awards = [
  {
    title: '2nd Place, Coding Day',
    year: '2026',
    desc: 'Achieved 2nd place in web development competition among all Informatics Engineering students.',
    image: 'award-coding-day.webp',
  },
  {
    title: 'The Best Thematic, Hackathon SRE ITB',
    year: '2026',
    desc: 'Awarded The Best Thematic at the SRE ITB 2026 Hackathon.',
    image: 'award-sre-itb.webp',
  },
];

const organizations = [
  { name: 'Himpunan Mahasiswa Teknik Informatika', role: 'Academic Cadre', period: 'Apr 2024 – May 2025' },
  { name: 'Bengel TI', role: 'Cadre', period: 'Mar 2024 – Mar 2025' },
  { name: 'Teaching Assistant — Basic Programming', role: 'TA', period: 'Feb 2025 – Aug 2025' },
  { name: 'Teaching Assistant — Algorithms & Data Structures', role: 'TA', period: 'Feb 2025 – Aug 2025' },
  { name: 'Festival Teknik Informatika', role: 'Chairperson', period: 'Aug 2024 – Sep 2024' },
  { name: 'Himpunan Mahasiswa Teknik Informatika', role: 'Chairperson', period: 'May 2025 – Present' },
  { name: 'Bengel Unida Technology Center', role: 'Head of Business Unit', period: 'Apr 2025 – Present' },
];
---

<Layout>

<!-- Navbar -->
<nav class="fixed top-0 left-0 right-0 z-50 glass">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="#" class="text-xl font-bold tracking-tight">
      <span class="text-brand-400">&lt;</span>
      <span class="text-white">FG</span>
      <span class="text-brand-400">/&gt;</span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm font-medium text-surface-300 hover:text-brand-400 transition-colors duration-200"
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Mobile Menu Button -->
    <button id="mobile-menu-btn" class="md:hidden text-surface-300 hover:text-brand-400 transition-colors" aria-label="Toggle menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-brand-900/50 px-6 py-4 space-y-3">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="block text-sm font-medium text-surface-300 hover:text-brand-400 transition-colors"
      >
        {link.label}
      </a>
    ))}
  </div>
</nav>

<!-- Hero Section -->
<section class="relative min-h-screen flex items-center justify-center bg-surface-950 bg-grid overflow-hidden">
  <!-- Radial glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[600px] bg-radial-glow"></div>

  <!-- Animated orbiting particles -->
  <div class="absolute top-1/4 left-1/4 w-3 h-3 rounded-full bg-brand-500/40 animate-float"></div>
  <div class="absolute top-1/3 right-1/4 w-2.5 h-2.5 rounded-full bg-brand-400/30 animate-float animation-delay-400" style="animation-duration: 8s;"></div>
  <div class="absolute bottom-1/3 left-1/3 w-4 h-4 rounded-full bg-brand-600/20 animate-float animation-delay-800" style="animation-duration: 7s;"></div>
  <div class="absolute top-1/2 right-1/6 w-2 h-2 rounded-full bg-brand-300/20 animate-float animation-delay-200" style="animation-duration: 9s;"></div>
  <div class="absolute bottom-1/4 right-1/3 w-3 h-3 rounded-full bg-brand-400/15 animate-float animation-delay-600" style="animation-duration: 10s;"></div>

  <!-- Orbit Ring -->
  <div class="absolute w-[300px] h-[300px] md:w-[400px] md:h-[400px] border border-brand-800/15 rounded-full">
    <div class="absolute top-1/2 left-0 w-3 h-3 -translate-y-1/2 rounded-full bg-brand-500 animate-orbit shadow-[0_0_20px_rgba(59,130,246,0.5)]"></div>
  </div>

  <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
    <!-- Availability Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass mb-8">
      <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
      <span class="text-sm font-medium text-surface-300">Available for collaboration</span>
    </div>

    <!-- Main Heading -->
    <h1 class="heading-xl mb-4">
      <span class="text-white">Hi, I'm </span>
      <span class="text-brand-400 glow-text">Farrel Ghozy</span>
    </h1>

    <!-- Dynamic Subtitle -->
    <p class="text-lg sm:text-xl md:text-2xl font-light text-surface-300 mb-3">
      <span id="typing-text" class="inline-block"></span>
      <span class="animate-pulse text-brand-400">|</span>
    </p>

    <!-- Description -->
    <p class="body-lg text-surface-400 max-w-2xl mx-auto mb-10">
      Full-stack development enthusiast, exploring machine learning,
      and building projects one commit at a time.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="#projects" class="btn-primary group">
        View My Work
        <span class="inline-block ml-1 transition-transform group-hover:translate-x-1">→</span>
      </a>
      <a href="#contact" class="btn-secondary">
        Get In Touch
      </a>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-5 h-5 text-brand-500/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </div>
</section>

<!-- About Section -->
<section id="about" class="py-24 md:py-32 relative">
  <div class="absolute inset-0 bg-grid-subtle opacity-40"></div>
  <div class="relative max-w-6xl mx-auto px-6">
    <div class="section-header reveal">
      <span class="section-number">01.</span>
      <h2 class="section-title">About Me</h2>
      <div class="section-line"></div>
    </div>

    <div class="grid md:grid-cols-5 gap-12 items-start">
      <!-- Text -->
      <div class="md:col-span-3 space-y-5 body-md reveal reveal-delay-1">
        <p class="text-surface-300">
          I'm an Informatics student at
          <span class="text-brand-400 font-medium">Universitas Darussalam Gontor</span>
          passionate about web development and machine learning. I love building projects
          that solve real problems.
        </p>
        <p class="text-surface-300">
          Currently working on a point-of-sale system for
          <span class="text-brand-400 font-medium">Unida Technology Centre</span>
          using Node.js, Express, and MongoDB — integrating WhatsApp bot
          automation and inventory management.
        </p>
        <p class="text-surface-300">
          I'm also exploring deep learning — comparing CNN architectures
          with Transfer Learning for image classification, and building
          ML pipelines with Python and Jupyter.
        </p>
        <p class="text-surface-300">
          Continuously learning new technologies and improving my skills
          through hands-on projects, coursework, and open source collaboration.
        </p>

        <!-- Quick Facts -->
        <div class="grid grid-cols-2 gap-4 pt-4">
          {[
            ['Web Development', '▹'],
            ['Machine Learning', '▹'],
            ['Android (Kotlin)', '▹'],
            ['Open Source', '▹'],
          ].map(([label, marker]) => (
            <div class="flex items-center gap-3 text-sm text-surface-300">
              <span class="text-brand-400">{marker}</span>
              <span>{label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Profile Card -->
      <div class="md:col-span-2 reveal reveal-delay-2">
        <div class="relative group">
          <div class="absolute -inset-0.5 bg-gradient-to-br from-brand-600 to-brand-800 rounded-2xl opacity-25 group-hover:opacity-40 blur transition-opacity duration-500"></div>
          <div class="relative bg-surface-800 border border-brand-800/25 rounded-2xl p-8 glow-card">
            <!-- Avatar -->
            <div class="w-32 h-32 mx-auto mb-6 rounded-full overflow-hidden ring-2 ring-brand-500/20 shadow-lg shadow-brand-900/30">
              <img src={`${basePath}fotoProfil.webp`} alt="Farrel Ghozy" class="w-full h-full object-cover" />
            </div>
            <div class="text-center space-y-2">
              <h3 class="heading-md">Farrel Ghozy Affifudin</h3>
              <p class="text-brand-400 text-sm font-medium">Informatics Student</p>
              <p class="text-surface-400 text-sm">Universitas Darussalam Gontor</p>
            </div>

            <!-- Social links in profile card -->
            <div class="mt-6 pt-6 border-t border-brand-800/25 flex justify-center gap-5">
              {[
                { href: 'https://github.com/FarrelGhozy', label: 'GitHub', viewBox: '0 0 24 24',
                  path: 'M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z' },
                { href: 'mailto:farrelafif05@gmail.com', label: 'Email', viewBox: '0 0 24 24', fill: 'none',
                  path: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' },
                { href: 'https://linkedin.com/in/farrelghozy', label: 'LinkedIn', viewBox: '0 0 24 24',
                  path: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z' },
                { href: 'https://instagram.com/farrelgzy', label: 'Instagram', viewBox: '0 0 24 24', fill: 'none',
                  path: 'M16.5 6.5h.01M12 2a10 10 0 00-3.16.54 10.01 10.01 0 00-6.3 6.3A10 10 0 0012 22a10 10 0 0010-10 10.01 10.01 0 00-6.3-6.3A10 10 0 0012 2zm0 4a6 6 0 100 12 6 6 0 000-12zm-4 6a4 4 0 118 0 4 4 0 01-8 0z' },
              ].map((social) => (
                <a
                  href={social.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-surface-400 hover:text-brand-400 transition-colors"
                  aria-label={social.label}
                >
                  <svg class="w-5 h-5" fill={social.fill || 'currentColor'} stroke={social.fill === 'none' ? 'currentColor' : 'none'} viewBox={social.viewBox}>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={social.path} />
                  </svg>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Skills Section -->
<section id="skills" class="py-24 md:py-32 bg-surface-900/50 relative">
  <div class="absolute inset-0 bg-grid-subtle opacity-30"></div>
  <div class="relative max-w-6xl mx-auto px-6">
    <div class="section-header reveal">
      <span class="section-number">02.</span>
      <h2 class="section-title">Tech Stack</h2>
      <div class="section-line"></div>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {skills.map((skill, idx) => (
        <div
          class="card-base p-6 reveal"
          class:list={{ 'reveal-delay-1': idx % 3 === 1, 'reveal-delay-2': idx % 3 === 2 }}
        >
          <!-- Category Icon -->
          <div class="w-11 h-11 rounded-xl bg-brand-950 border border-brand-800/30 flex items-center justify-center mb-4 group-hover:border-brand-600/50 transition-colors">
            {skill.icon === 'frontend' && (
              <svg class="w-5.5 h-5.5 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            )}
            {skill.icon === 'backend' && (
              <svg class="w-5.5 h-5.5 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" /></svg>
            )}
            {skill.icon === 'mobile' && (
              <svg class="w-5.5 h-5.5 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
            )}
            {skill.icon === 'infra' && (
              <svg class="w-5.5 h-5.5 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
            )}
            {skill.icon === 'ml' && (
              <svg class="w-5.5 h-5.5 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>
            )}
            {skill.icon === 'nontech' && (
              <svg class="w-5.5 h-5.5 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            )}
          </div>

          <h3 class="text-lg font-bold text-white mb-4">{skill.category}</h3>

          <div class="flex flex-wrap gap-2">
            {skill.items.map((item) => (
              <div class="group/tag relative">
                <span class="tag">{item.name}</span>
                <!-- Skill level dots tooltip -->
                <div class="absolute -bottom-6 left-1/2 -translate-x-1/2 opacity-0 group-hover/tag:opacity-100 transition-opacity pointer-events-none flex gap-0.5">
                  {Array.from({ length: 5 }, (_, i) => (
                    <div
                      class="skill-dot"
                      class:list={{ 'filled': i < item.level }}
                    ></div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Projects Section -->
<section id="projects" class="py-24 md:py-32 relative">
  <div class="absolute inset-0 bg-grid-subtle opacity-20"></div>
  <div class="relative max-w-6xl mx-auto px-6">
    <div class="section-header reveal">
      <span class="section-number">03.</span>
      <h2 class="section-title">Featured Projects</h2>
      <div class="section-line"></div>
    </div>

    <div class="space-y-6">
      {projects.map((project, idx) => (
        <div class="card-base overflow-hidden reveal" class:list={{ 'reveal-delay-1': idx % 2 === 1 }}>
          <div class="p-8 md:p-10">
            <div class="flex items-start justify-between mb-3">
              <div>
                <div class="flex items-center gap-3 mb-2">
                  <h3 class="heading-md group-hover:text-brand-400 transition-colors">
                    {project.title}
                  </h3>
                  <span
                    class="px-2.5 py-0.5 text-xs font-semibold rounded-full"
                    class:list={{
                      'badge-production': project.status === 'Production',
                      'badge-active': project.status === 'Active',
                      'badge-research': project.status === 'Research',
                    }}
                  >
                    {project.status}
                  </span>
                </div>
                <p class="body-md text-surface-400 max-w-2xl">
                  {project.desc}
                </p>
              </div>
              <a
                href={project.link}
                target="_blank"
                rel="noopener noreferrer"
